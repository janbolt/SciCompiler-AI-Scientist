# Choose ONE provider
LLM_PROVIDER=openai

# OpenAI (default)
OPENAI_API_KEY=
LLM_FAST_MODEL=gpt-4o-mini
LLM_PLAN_MODEL=gpt-4o

# Anthropic (alternative — set LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
# LLM_FAST_MODEL=claude-haiku-4-5-20251001
# LLM_PLAN_MODEL=claude-sonnet-4-6

# Optional: Tavily web search (not used in MVP pipeline)
TAVILY_API_KEY=

DATABASE_URL=sqlite:///./predictivebio.db
