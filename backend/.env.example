# PredictiveBio backend env example.
# Copy this file to backend/.env and fill in real values.
# NEVER commit backend/.env (it is gitignored).
#
# For CI and offline development, set USE_STUB_AGENTS=true so agents
# return deterministic demo output without contacting any LLM provider.

OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE
LLM_MODEL=gpt-5.5
LLM_MAX_RETRIES=3
USE_STUB_AGENTS=false

# protocols.io OAuth credentials
# Get your client_id and client_secret at: https://www.protocols.io/developers
# Then run:  python backend/scripts/fetch_protocols_io_token.py
# That script opens a browser, completes the OAuth flow, and writes the
# access_token below automatically.
PROTOCOLS_IO_CLIENT_ID=your_client_id_here
PROTOCOLS_IO_CLIENT_SECRET=your_client_secret_here

# Written automatically by fetch_protocols_io_token.py — do not edit manually.
PROTOCOLS_IO_TOKEN=your_token_here
PROTOCOLS_IO_REFRESH_TOKEN=

# Semantic Scholar API key — raises rate limit from 1 req/s to 100 req/s.
# Get a free key at: https://www.semanticscholar.org/product/api
# Leave blank to use unauthenticated (may hit rate limits on busy prompts).
SEMANTIC_SCHOLAR_API_KEY=
