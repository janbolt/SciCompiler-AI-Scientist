# PredictiveBio backend env example.
# Copy this file to backend/.env and fill in real values.
# NEVER commit backend/.env (it is gitignored).
#
# For CI and offline development, set USE_STUB_AGENTS=true so agents
# return deterministic demo output without contacting any LLM provider.

OPENAI_API_KEY=sk-proj-YOUR_KEY_HERE
LLM_MODEL=gpt-4o-mini
LLM_MAX_RETRIES=3
USE_STUB_AGENTS=false

# protocols.io client access token — read-only access to all public protocols
# Get yours at: https://www.protocols.io/developers
PROTOCOLS_IO_TOKEN=your_token_here
